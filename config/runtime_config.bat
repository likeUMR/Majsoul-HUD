@echo off
REM AI_Mahjong runtime config / AI_Mahjong 运行配置
REM Edit the ports below if 50000 or 8080 is already in use.
REM 如果 50000 或 8080 已被占用，可以直接修改下面的端口。
REM HUD_EXTRA_SCALE controls an extra HUD zoom factor. 1.2 means 120 percent.
REM HUD_EXTRA_SCALE 用于额外 HUD 缩放。1.2 表示整体放大到 120%。

set "ALGO_HOST=127.0.0.1"
set "ALGO_PORT=50000"
set "PROXY_HOST=127.0.0.1"
set "PROXY_PORT=8080"
set "HUD_EXTRA_SCALE=1.0"
